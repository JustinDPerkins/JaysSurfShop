# LLM for chat-rag: openai (local default) or bedrock (AWS ECS/EKS)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here

# Bedrock models (when LLM_PROVIDER=bedrock on AWS)
# AI_MODEL_CHAT=amazon.nova-lite-v1:0
# AI_MODEL_EMBED=amazon.titan-embed-text-v2:0
# ORDERS_TABLE=jays-surf-shop-demo-orders

# Service URLs (defaults work with docker-compose)
CHAT_SERVICE_URL=http://localhost:8001
BOARD_SERVICE_URL=http://localhost:8002
NEXT_PUBLIC_CHAT_SERVICE_URL=http://localhost:8001
NEXT_PUBLIC_BOARD_SERVICE_URL=http://localhost:8002

# Deployment metadata (set automatically on AWS ECS)
ENVIRONMENT=local
DEPLOYMENT_ID=local
SERVICE_NAME=frontend
LOG_FORMAT=json
NEXT_PUBLIC_APP_ENV=local

# Optional: image model (gpt-image-1, gpt-image-1.5, dall-e-3, dall-e-2)
# AI_MODEL=gpt-image-1
# AWS_REGION=us-east-1
# TF_VAR_openai_api_key=sk-...
